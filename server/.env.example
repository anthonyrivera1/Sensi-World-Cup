# ============================================================
# Sensi World Cup — server environment
# Copy to ".env" and fill in. EVERYTHING is optional: with no .env
# the server runs fully in DEMO mode. Add keys to go live — no code
# change required.
# ============================================================

# ---- server ----
PORT=3000
NODE_ENV=development
# Use a long random string in production. Sessions sign with this.
SESSION_SECRET=change-me-to-a-long-random-string
# Set to true when served over HTTPS (production)
SESSION_SECURE=false

# ============================================================
# LIVE SCORES  (provider: football-data.org, v4)
# Leave FOOTBALL_DATA_TOKEN blank to keep the built-in demo feed.
# The moment a token is present, /api/scores serves the real feed.
# Free signup: https://www.football-data.org/client/register
# ============================================================
FOOTBALL_DATA_TOKEN=
# defaults below are correct for the FIFA World Cup on football-data.org
SCORES_PROVIDER=football-data
FOOTBALL_DATA_BASE=https://api.football-data.org/v4
FOOTBALL_COMPETITION=WC
# cache window (ms) — the real rate-limit guard. ~1 upstream call/window:
# 15s => ~4 calls/min, within the free tier's 10 req/min.
SCORES_CACHE_TTL_MS=15000
# set SCORES_PROVIDER=demo to force the demo feed even with a token

# ---- alternate provider: api-football / api-sports.io ----
# SCORES_PROVIDER=api-football
# FOOTBALL_API_KEY=
# FOOTBALL_API_BASE=https://v3.football.api-sports.io
# FOOTBALL_LEAGUE_ID=1
# FOOTBALL_SEASON=2026

# ============================================================
# OKTA SSO  (identity + roster)
# Leave blank to keep the demo identity + roster. Fill all three of
# ISSUER / CLIENT_ID / CLIENT_SECRET to enable real Okta SSO.
# ============================================================
OKTA_ISSUER=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_REDIRECT_URI=http://localhost:3000/auth/callback
OKTA_POST_LOGOUT_URI=http://localhost:3000/
# profile attribute (or "groups") that carries the user's department
OKTA_DEPT_CLAIM=department

# ============================================================
# DATABASE
# ============================================================
DB_FILE=./data/sensi-wc.sqlite

# ============================================================
# PHASE LIFECYCLE
# Optional hard start time (ISO). Tournament also auto-starts when the
# feed reports any live/finished match.
# ============================================================
# TOURNAMENT_START=2026-06-11T20:00:00Z
